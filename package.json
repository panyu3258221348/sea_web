{
  "name": "sea_web",
  "version": "0.1.0",
  "private": true,
  "description": "Sea Web Application",
  "main": "desktop/main.js",
  "scripts": {
    "serve": "vue-cli-service serve",
    "build": "vue-cli-service build",
    "lint": "eslint --ext .js,.vue src/",
    "lint:fix": "eslint --ext .js,.vue src/ --fix",
    "electron:serve": "concurrently -k \"cross-env BROWSER=none vue-cli-service serve\" \"wait-on http://localhost:8080 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "vue-cli-service build && electron-builder --config desktop/electron-builder.json",
    "electron:build:linux": "vue-cli-service build && electron-builder --config desktop/electron-builder.json --linux",
    "electron:build:win": "vue-cli-service build && electron-builder --config desktop/electron-builder.json --win",
    "electron:build:all": "vue-cli-service build && electron-builder --config desktop/electron-builder.json --linux --win",
    "cap:sync": "vue-cli-service build && npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:build:android": "vue-cli-service build && npx cap sync android"
  },
  "dependencies": {
    "@capacitor/android": "^5.7.8",
    "@capacitor/cli": "^5.7.8",
    "@capacitor/core": "^5.7.8",
    "core-js": "^3.8.3",
    "roslib": "1.3.0",
    "vue": "^3.2.13"
  },
  "devDependencies": {
    "@babel/core": "^7.12.16",
    "@babel/eslint-parser": "^7.12.16",
    "@babel/plugin-transform-class-properties": "^7.27.1",
    "@babel/plugin-transform-private-methods": "^7.27.1",
    "@vue/cli-plugin-babel": "~5.0.0",
    "@vue/cli-plugin-eslint": "~5.0.0",
    "@vue/cli-service": "~5.0.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "eslint": "^7.32.0",
    "eslint-plugin-vue": "^8.0.3",
    "wait-on": "^7.2.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}
